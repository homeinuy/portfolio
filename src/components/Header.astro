---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/projects/', label: 'Servicios' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contact/', label: 'Contacto' },
];
---

<header class="border-b border-gray-100">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-serif text-xl font-bold text-gray-900 hover:text-gray-700 transition">
      Agust&iacute;n D&iacute;az
    </a>
    <ul class="flex gap-6 text-sm font-medium">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'transition hover:text-gray-900',
              currentPath === link.href || currentPath.startsWith(link.href) && link.href !== '/'
                ? 'text-gray-900'
                : 'text-gray-500',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
