---
interface Props {
  title: string;
  description: string;
  slug: string;
  image?: string;
  tech?: string[];
}

const { title, description, slug, image, tech } = Astro.props;
---

<a href={`/projects/${slug}/`} class="group block">
  <article class="border border-gray-100 rounded-lg overflow-hidden hover:border-gray-300 transition">
    {image && (
      <img src={image} alt={title} class="w-full h-48 object-cover" />
    )}
    <div class="p-6">
      <h3 class="font-serif text-lg font-semibold text-gray-900 group-hover:text-gray-600 transition">
        {title}
      </h3>
      <p class="mt-2 text-sm text-gray-600 leading-relaxed">{description}</p>
      {tech && tech.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tech.map((t) => (
            <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded">
              {t}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
