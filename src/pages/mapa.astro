---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const desarrollos = await getCollection('desarrollos');
const proyectosConUbicacion = desarrollos
  .filter((d) => d.data.lat && d.data.lng)
  .map((d) => ({
    title: d.data.title,
    description: d.data.description,
    location: d.data.location || '',
    status: d.data.status || '',
    lat: d.data.lat,
    lng: d.data.lng,
    slug: d.id,
    image: d.data.image || '',
  }));
---

<BaseLayout title="Mapa de Proyectos — Agust&iacute;n D&iacute;az" description="Encontr&aacute; nuestros proyectos inmobiliarios en el mapa">
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h1 class="font-serif text-4xl font-bold text-gray-900">Mapa de Proyectos</h1>
      <p class="mt-4 text-lg text-gray-600">
        Explora nuestros proyectos inmobiliarios en Punta del Este y alrededores.
      </p>
    </div>
  </section>

  <section class="px-6 pb-16">
    <div class="max-w-5xl mx-auto">
      <div id="map" class="w-full h-[500px] rounded-lg border border-gray-200 shadow-sm"></div>
    </div>
  </section>

  <!-- Listado debajo del mapa -->
  <section class="px-6 pb-16">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-2xl font-bold text-gray-900 mb-6">Todos los proyectos</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {proyectosConUbicacion.map((p) => (
          <a href={`/desarrollos/${p.slug}/`} class="group block border border-gray-100 rounded-lg p-5 hover:border-gray-300 transition">
            {p.status && (
              <span class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full font-medium">
                {p.status}
              </span>
            )}
            <h3 class="mt-2 font-serif text-lg font-semibold text-gray-900 group-hover:text-gray-600 transition">
              {p.title}
            </h3>
            <p class="mt-1 text-sm text-gray-600">{p.description}</p>
            {p.location && (
              <p class="mt-2 text-xs text-gray-400">📍 {p.location}</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline define:vars={{ proyectos: proyectosConUbicacion }}>
    document.addEventListener('DOMContentLoaded', function () {
      // Centro en Punta del Este
      var map = L.map('map').setView([-34.9467, -54.9358], 13);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      // Agregar marcadores
      var bounds = [];
      proyectos.forEach(function (p) {
        var marker = L.marker([p.lat, p.lng]).addTo(map);

        var popupContent = '<div style="min-width: 200px; font-family: system-ui, sans-serif;">' +
          '<h3 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700;">' + p.title + '</h3>' +
          '<p style="margin: 0 0 6px 0; font-size: 13px; color: #6b7280;">' + p.description + '</p>';

        if (p.location) {
          popupContent += '<p style="margin: 0 0 6px 0; font-size: 12px; color: #9ca3af;">📍 ' + p.location + '</p>';
        }

        if (p.status) {
          popupContent += '<span style="display: inline-block; font-size: 11px; padding: 2px 8px; background: #dcfce7; color: #15803d; border-radius: 12px;">' + p.status + '</span><br>';
        }

        popupContent += '<a href="/desarrollos/' + p.slug + '/" style="display: inline-block; margin-top: 8px; font-size: 13px; color: #111827; text-decoration: underline;">Ver proyecto →</a>';
        popupContent += '</div>';

        marker.bindPopup(popupContent);
        bounds.push([p.lat, p.lng]);
      });

      // Si hay múltiples marcadores, ajustar el zoom para verlos todos
      if (bounds.length > 1) {
        map.fitBounds(bounds, { padding: [50, 50] });
      }
    });
  </script>
</BaseLayout>
