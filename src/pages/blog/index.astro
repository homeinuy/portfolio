---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog — Mi Portfolio" description="Articulos sobre desarrollo web y tecnologia">
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-4 text-lg text-gray-600">
        Articulos sobre lo que aprendo en el mundo del desarrollo web.
      </p>
      <div class="mt-10">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
