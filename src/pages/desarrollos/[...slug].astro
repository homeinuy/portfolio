---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const desarrollos = await getCollection('desarrollos');
  return desarrollos.map((desarrollo) => ({
    params: { slug: desarrollo.id },
    props: { desarrollo },
  }));
}

const { desarrollo } = Astro.props;
const { Content } = await render(desarrollo);
---

<BaseLayout title={`${desarrollo.data.title} — Agust\u00edn D\u00edaz`} description={desarrollo.data.description}>
  <article class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/desarrollos/" class="text-sm text-gray-500 hover:text-gray-900 transition">
        &larr; Volver a proyectos
      </a>

      <h1 class="mt-6 font-serif text-4xl font-bold text-gray-900">{desarrollo.data.title}</h1>
      <p class="mt-4 text-lg text-gray-600">{desarrollo.data.description}</p>

      <div class="mt-4 flex flex-wrap gap-4 text-sm text-gray-500">
        {desarrollo.data.location && (
          <span>📍 {desarrollo.data.location}</span>
        )}
        {desarrollo.data.status && (
          <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">
            {desarrollo.data.status}
          </span>
        )}
      </div>

      {/* Video de YouTube */}
      {desarrollo.data.youtubeId && (
        <div class="mt-8 aspect-video rounded-lg overflow-hidden">
          <iframe
            width="100%"
            height="100%"
            src={`https://www.youtube.com/embed/${desarrollo.data.youtubeId}`}
            title={desarrollo.data.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      )}

      <div class="mt-10 prose prose-gray max-w-none">
        <Content />
      </div>

      {/* CTA de contacto */}
      <div class="mt-12 p-8 bg-gray-50 rounded-lg text-center">
        <h3 class="font-serif text-xl font-bold text-gray-900">¿Te interesa este proyecto?</h3>
        <p class="mt-2 text-gray-600">Contactame para recibir mas informacion y asesoramiento personalizado.</p>
        <a
          href="/contact/"
          class="mt-4 inline-block px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition"
        >
          Consultar sobre este proyecto
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
