---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto — Mi Portfolio" description="Ponete en contacto conmigo">
  <section class="py-16 px-6">
    <div class="max-w-xl mx-auto">
      <h1 class="font-serif text-4xl font-bold text-gray-900">Contacto</h1>
      <p class="mt-4 text-lg text-gray-600">
        Tenes un proyecto en mente o simplemente queres saludar? Enviame un mensaje.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact/success/"
        class="mt-10 space-y-6"
      >
        <p class="hidden">
          <label>No completar: <input name="bot-field" /></label>
        </p>
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700">Nombre</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-gray-500 focus:ring-1 focus:ring-gray-500 outline-none transition"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-gray-500 focus:ring-1 focus:ring-gray-500 outline-none transition"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700">Mensaje</label>
          <textarea
            name="message"
            id="message"
            rows="5"
            required
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-gray-500 focus:ring-1 focus:ring-gray-500 outline-none transition resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition"
        >
          Enviar mensaje
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
