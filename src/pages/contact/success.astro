---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mensaje enviado — Mi Portfolio">
  <section class="py-24 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <h1 class="font-serif text-4xl font-bold text-gray-900">Gracias!</h1>
      <p class="mt-4 text-lg text-gray-600">
        Tu mensaje fue enviado correctamente. Te respondere lo antes posible.
      </p>
      <a
        href="/"
        class="mt-8 inline-block px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
