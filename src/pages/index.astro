---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import DesarrolloCard from '../components/DesarrolloCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allDesarrollos = await getCollection('desarrollos');
const featuredDesarrollos = allDesarrollos
  .filter((d) => d.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Agust&iacute;n D&iacute;az — Asesor de Inversiones Inmobiliarias">
  <!-- Hero -->
  <section class="py-16 md:py-24 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <!-- Foto -->
      <div class="flex-shrink-0">
        <img
          src="/images/agustin-foto.png"
          alt="Agustín Díaz"
          class="w-64 md:w-80"
        />
      </div>
      <!-- Texto -->
      <div class="text-center md:text-left">
        <img src="/images/firma-agustin.png" alt="Agustín Díaz" class="h-28 -mb-2 mx-auto md:mx-0" />
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
          Asesor de Inversiones<br/>Inmobiliarias
        </h1>
        <p class="mt-5 text-lg text-gray-600 leading-relaxed max-w-lg">
          Te ayudo a tomar las mejores decisiones para hacer crecer
          tu patrimonio a trav&eacute;s del mercado inmobiliario.
        </p>
        <div class="mt-8 flex gap-4 justify-center md:justify-start">
          <a
            href="/projects/"
            class="inline-block px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition"
          >
            Ver servicios
          </a>
          <a
            href="/contact/"
            class="inline-block px-6 py-3 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:border-gray-500 transition"
          >
            Contacto
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyectos destacados -->
  {featuredProjects.length > 0 && (
    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Servicios destacados</h2>
          <a href="/projects/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              image={project.data.image}
              tech={project.data.tech}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Proyectos inmobiliarios -->
  {featuredDesarrollos.length > 0 && (
    <section class="py-16 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Proyectos inmobiliarios</h2>
          <a href="/desarrollos/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredDesarrollos.map((d) => (
            <DesarrolloCard
              title={d.data.title}
              description={d.data.description}
              slug={d.id}
              image={d.data.image}
              location={d.data.location}
              status={d.data.status}
              priceFrom={d.data.priceFrom}
              priceCurrency={d.data.priceCurrency}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Posts recientes -->
  {recentPosts.length > 0 && (
    <section class="py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Posts recientes</h2>
          <a href="/blog/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div>
          {recentPosts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA de contacto -->
  <section class="py-20 px-6 bg-gray-900 text-white">
    <div class="max-w-3xl mx-auto text-center">
      <img src="/images/homein.png" alt="Homein" class="h-8 mx-auto mb-6" />
      <h2 class="font-serif text-3xl font-bold">¿Listo para invertir en bienes raíces?</h2>
      <p class="mt-4 text-gray-300 text-lg max-w-xl mx-auto">
        Te asesoro de forma personalizada para encontrar la mejor oportunidad de inversión inmobiliaria. Escribime y empezamos.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/59891066060?text=Hola%20Agust%C3%ADn!%20Me%20interesa%20recibir%20asesoramiento%20sobre%20inversiones%20inmobiliarias."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-green-600 text-white font-medium rounded-lg hover:bg-green-500 transition text-lg"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escribime por WhatsApp
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-medium rounded-lg hover:bg-white hover:text-gray-900 transition text-lg"
        >
          Enviar mensaje
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
