---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import DesarrolloCard from '../components/DesarrolloCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allDesarrollos = await getCollection('desarrollos');
const featuredDesarrollos = allDesarrollos
  .filter((d) => d.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Agust&iacute;n D&iacute;az — Asesor de Inversiones Inmobiliarias">
  <!-- Hero -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-5xl font-bold text-gray-900 leading-tight">
        Hola, soy <span class="text-gray-500">Agust&iacute;n D&iacute;az</span>
      </h1>
      <p class="mt-6 text-xl text-gray-600 leading-relaxed">
        Asesor de Inversiones Inmobiliarias. Te ayudo a tomar las mejores decisiones
        para hacer crecer tu patrimonio a trav&eacute;s del mercado inmobiliario.
      </p>
      <div class="mt-8 flex gap-4">
        <a
          href="/projects/"
          class="inline-block px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition"
        >
          Ver servicios
        </a>
        <a
          href="/contact/"
          class="inline-block px-6 py-3 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:border-gray-500 transition"
        >
          Contacto
        </a>
      </div>
    </div>
  </section>

  <!-- Proyectos destacados -->
  {featuredProjects.length > 0 && (
    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Servicios destacados</h2>
          <a href="/projects/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              image={project.data.image}
              tech={project.data.tech}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Proyectos inmobiliarios -->
  {featuredDesarrollos.length > 0 && (
    <section class="py-16 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Proyectos inmobiliarios</h2>
          <a href="/desarrollos/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredDesarrollos.map((d) => (
            <DesarrolloCard
              title={d.data.title}
              description={d.data.description}
              slug={d.id}
              image={d.data.image}
              location={d.data.location}
              status={d.data.status}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Posts recientes -->
  {recentPosts.length > 0 && (
    <section class="py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold text-gray-900">Posts recientes</h2>
          <a href="/blog/" class="text-sm text-gray-500 hover:text-gray-900 transition">
            Ver todos &rarr;
          </a>
        </div>
        <div>
          {recentPosts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
