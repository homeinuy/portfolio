---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Mi Portfolio`} description={project.data.description}>
  <article class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/projects/" class="text-sm text-gray-500 hover:text-gray-900 transition">
        &larr; Volver a proyectos
      </a>

      <h1 class="mt-6 font-serif text-4xl font-bold text-gray-900">{project.data.title}</h1>
      <p class="mt-4 text-lg text-gray-600">{project.data.description}</p>

      {project.data.tech && project.data.tech.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {project.data.tech.map((t: string) => (
            <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded">{t}</span>
          ))}
        </div>
      )}

      <div class="mt-4 flex gap-4 text-sm">
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-gray-900 underline hover:text-gray-600 transition">
            Ver en vivo
          </a>
        )}
        {project.data.repoUrl && (
          <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="text-gray-900 underline hover:text-gray-600 transition">
            Codigo fuente
          </a>
        )}
      </div>

      <div class="mt-10 prose prose-gray max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
